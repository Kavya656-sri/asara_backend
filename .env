# Shared environment variables for FSM Microservices

# ─── Shared ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
NODE_ENV=development

# ─── Database (default for local dev) ─────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=company_contact

# ─── Message Queue ────────────────────────────────────
RABBITMQ_URL=amqp://fsm:fsm_password@localhost:5672

# ─── File Storage ─────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=fsm
S3_SECRET_KEY=fsm_password
S3_BUCKET=fsm-uploads
BASE_URL=http://localhost:3000

# ─── External APIs ────────────────────────────────────
FRESHDESK_URL=https://your-domain.freshdesk.com
FRESHDESK_API_KEY=your-freshdesk-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-key
OPENAI_API_KEY=your-openai-api-key
VITE_SECRET_KEY=your-aes-encryption-key

# ─── Service URLs (for inter-service communication) ───
AUTH_SERVICE_URL=http://localhost:3001
MASTER_DATA_SERVICE_URL=http://localhost:3002
PROJECT_SERVICE_URL=http://localhost:3003
TASK_SERVICE_URL=http://localhost:3004
TICKET_SERVICE_URL=http://localhost:3005
ATTENDANCE_SERVICE_URL=http://localhost:3006
FINANCE_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
REPORTING_SERVICE_URL=http://localhost:3009
AI_SERVICE_URL=http://localhost:3010